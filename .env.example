# LLM Provider Configuration
# Support Qwen (通义千问) via OpenAI-compatible API
DASHSCOPE_API_KEY=sk-xxxxx
MODEL_ID=qwen-plus

# Optional: custom base URL for API-compatible providers
# Default: https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Telegram (optional, for s04_channels.py)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Feishu / Lark (optional, for s04_channels.py)
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_DOMAIN=feishu    # "feishu" for domestic, "lark" for international

# Heartbeat (optional, for s07_heartbeat_cron.py)
# HEARTBEAT_INTERVAL=1800
# HEARTBEAT_ACTIVE_START=9
# HEARTBEAT_ACTIVE_END=22
